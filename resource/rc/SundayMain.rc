IDD_ABOUTBOX DIALOGEX 0, 0, 215, 196
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_TOOLWINDOW
CAPTION "버전 정보 - SUNDAY Maker"
FONT 8, "돋움", 0, 0, 0x0
BEGIN
    ICON            IDI_SUNDAY,IDC_MYICON,10,10,18,21
    LTEXT           "SUNDAY Maker, Version 2026.04.121",IDC_STATIC,36,6,168,8,SS_NOPREFIX
    LTEXT           "Copyright (C) 2026 Daleth",IDC_STATIC,36,18,168,8
    LTEXT           "Site : https://github.com/Da1eth",IDC_STATIC,36,30,168,8
    DEFPUSHBUTTON   "OK",IDOK,84,180,48,12,WS_GROUP
    EDITTEXT        IDE_ABOUT_DISP,6,42,204,132,ES_MULTILINE | ES_READONLY | NOT WS_BORDER,WS_EX_STATICEDGE
END

