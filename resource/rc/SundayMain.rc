IDC_SUNDAY MENU
BEGIN
    POPUP "파일(&F)"
    BEGIN
        MENUITEM ORR_UI_LABEL_NEWFILE,                IDM_NEWFILE
        MENUITEM ORR_UI_LABEL_OPEN,                   IDM_OPEN
        MENUITEM ORR_UI_LABEL_OPEN_HISTORY,           IDM_OPEN_HISTORY
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_OVERWRITESAVE,          IDM_OVERWRITESAVE
        MENUITEM ORR_UI_LABEL_RENAMESAVE,             IDM_RENAMESAVE
        MENUITEM ORR_UI_LABEL_IMAGE_SAVE,             IDM_IMAGE_SAVE
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_FILE_CLOSE,             IDM_FILE_CLOSE
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_GENERAL_OPTION,         IDM_GENERAL_OPTION
        MENUITEM ORR_UI_LABEL_MENUEDIT_DLG_OPEN,      IDM_MENUEDIT_DLG_OPEN
        MENUITEM ORR_UI_LABEL_COLOUR_EDIT_OPEN,       IDM_COLOUR_EDIT_OPEN
        MENUITEM ORR_UI_LABEL_ACCELKEY_EDIT_DLG_OPEN, IDM_ACCELKEY_EDIT_DLG_OPEN
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_ABOUT,                  IDM_ABOUT
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_EXIT,                   IDM_EXIT
    END
    POPUP "편집(&E)"
    BEGIN
        MENUITEM ORR_UI_LABEL_UNDO,                   IDM_UNDO
        MENUITEM ORR_UI_LABEL_REDO,                   IDM_REDO
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_CUT,                    IDM_CUT
        MENUITEM ORR_UI_LABEL_COPY,                   IDM_COPY
        MENUITEM ORR_UI_LABEL_PASTE,                  IDM_PASTE
        MENUITEM ORR_UI_LABEL_DELETE,                 IDM_DELETE
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_SJISCOPY_ALL,           IDM_SJISCOPY_ALL
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_ALLSEL,                 IDM_ALLSEL
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_SQSELECT,               IDM_SQSELECT
        MENUITEM ORR_UI_LABEL_SQUARE_PASTE,           IDM_SQUARE_PASTE
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_LAYERBOX,               IDM_LAYERBOX
        MENUITEM ORR_UI_LABEL_EXTRACTION_MODE,        IDM_EXTRACTION_MODE
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_FIND_DLG_OPEN,          IDM_FIND_DLG_OPEN
        MENUITEM ORR_UI_LABEL_FIND_HIGHLIGHT_OFF,     IDM_FIND_HIGHLIGHT_OFF
    END
    POPUP "삽입(&I)"
    BEGIN
        POPUP ORR_UI_LABEL_MN_UNISPACE
        BEGIN
            MENUITEM ORR_UI_LABEL_IN_01SPACE,         IDM_IN_01SPACE
            MENUITEM ORR_UI_LABEL_IN_02SPACE,         IDM_IN_02SPACE
            MENUITEM ORR_UI_LABEL_IN_03SPACE,         IDM_IN_03SPACE
            MENUITEM ORR_UI_LABEL_IN_04SPACE,         IDM_IN_04SPACE
            MENUITEM ORR_UI_LABEL_IN_05SPACE,         IDM_IN_05SPACE
            MENUITEM ORR_UI_LABEL_IN_08SPACE,         IDM_IN_08SPACE
            MENUITEM ORR_UI_LABEL_IN_10SPACE,         IDM_IN_10SPACE
            MENUITEM ORR_UI_LABEL_IN_16SPACE,         IDM_IN_16SPACE
        END
        POPUP ORR_UI_LABEL_MN_COLOUR_SEL
        BEGIN
            MENUITEM ORR_UI_LABEL_INSTAG_SPO,         IDM_INSTAG_SPO
            MENUITEM ORR_UI_LABEL_INSTAG_COLOUR,      IDM_INSTAG_COLOUR
            MENUITEM ORR_UI_LABEL_INSTAG_GRADIENT,    IDM_INSTAG_GRADIENT
        END
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_FRMINSBOX_OPEN,         IDM_FRMINSBOX_OPEN
        MENUITEM ORR_UI_LABEL_MN_INSFRAME_SEL,        IDM_MN_INSFRAME_SEL
        MENUITEM ORR_UI_LABEL_INSFRAME_EDIT,          IDM_INSFRAME_EDIT
        MENUITEM ORR_UI_LABEL_MN_USER_REFS,           IDM_MN_USER_REFS
    END
    POPUP "변형(&P)"
    BEGIN
        MENUITEM ORR_UI_LABEL_RIGHT_GUIDE_SET,        IDM_RIGHT_GUIDE_SET
        MENUITEM ORR_UI_LABEL_INS_TOPSPACE,           IDM_INS_TOPSPACE
        MENUITEM ORR_UI_LABEL_DEL_TOPSPACE,           IDM_DEL_TOPSPACE
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_DEL_LASTSPACE,          IDM_DEL_LASTSPACE
        MENUITEM ORR_UI_LABEL_DEL_LASTLETTER,         IDM_DEL_LASTLETTER
        MENUITEM ORR_UI_LABEL_FILL_SPACE,             IDM_FILL_SPACE
        MENUITEM ORR_UI_LABEL_FILL_ZENSP,             IDM_FILL_ZENSP
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_HEADHALF_EXCHANGE,      IDM_HEADHALF_EXCHANGE
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_MIRROR_INVERSE,         IDM_MIRROR_INVERSE
        MENUITEM ORR_UI_LABEL_UPSET_INVERSE,          IDM_UPSET_INVERSE
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_INCREMENT_DOT,          IDM_INCREMENT_DOT
        MENUITEM ORR_UI_LABEL_DECREMENT_DOT,          IDM_DECREMENT_DOT
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_INCR_DOT_LINES,         IDM_INCR_DOT_LINES
        MENUITEM ORR_UI_LABEL_DECR_DOT_LINES,         IDM_DECR_DOT_LINES
        MENUITEM ORR_UI_LABEL_DOT_SPLIT_LEFT,         IDM_DOT_SPLIT_LEFT
        MENUITEM ORR_UI_LABEL_DOT_SPLIT_RIGHT,        IDM_DOT_SPLIT_RIGHT
        MENUITEM SEPARATOR
        POPUP "도트 조정"
        BEGIN
            MENUITEM ORR_UI_LABEL_DOTDIFF_LOCK,       IDM_DOTDIFF_LOCK
            MENUITEM ORR_UI_LABEL_DOTDIFF_ADJT,       IDM_DOTDIFF_ADJT
        END
    END
    POPUP "표시(&N)"
    BEGIN
        MENUITEM ORR_UI_LABEL_SPACE_VIEW_TOGGLE,      IDM_SPACE_VIEW_TOGGLE
        MENUITEM ORR_UI_LABEL_GRID_VIEW_TOGGLE,       IDM_GRID_VIEW_TOGGLE
        MENUITEM ORR_UI_LABEL_RIGHT_RULER_TOGGLE,     IDM_RIGHT_RULER_TOGGLE
        MENUITEM ORR_UI_LABEL_UNDER_RULER_TOGGLE,     IDM_UNDER_RULER_TOGGLE
        MENUITEM SEPARATOR
        MENUITEM ORR_UI_LABEL_PAGELIST_VIEW,          IDM_PAGELIST_VIEW
        MENUITEM ORR_UI_LABEL_INSERT_PALETTE,         IDM_INSERT_PALETTE
        MENUITEM ORR_UI_LABEL_BRUSH_PALETTE,          IDM_BRUSH_PALETTE
        MENUITEM ORR_UI_LABEL_TRACE_MODE_ON,          IDM_TRACE_MODE_ON
        MENUITEM ORR_UI_LABEL_ON_PREVIEW,             IDM_ON_PREVIEW
    END
END

IDM_MULTIFILE_POPUP MENU
BEGIN
    POPUP "복수 파일 탭"
    BEGIN
        MENUITEM "저장하기",                        IDM_OVERWRITESAVE
        MENUITEM "다른 이름으로 저장하기",          IDM_RENAMESAVE
        MENUITEM SEPARATOR
        MENUITEM "파일 닫기",                       IDM_FILE_CLOSE
    END
END

