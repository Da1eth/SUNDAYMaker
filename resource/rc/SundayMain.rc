            VALUE "LegalCopyright", "Copyright (C) 2026 Daleth"
            VALUE "LegalTrademarks", "License : GPLv3"
            VALUE "ProductName", "SUNDAY Maker"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x412, 1200
    END
END

